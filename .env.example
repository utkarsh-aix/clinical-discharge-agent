# Required: pick one LLM provider
GEMINI_API_KEY=your-gemini-api-key-here

# OR use Groq (free tier available)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Optional
MAX_AGENT_STEPS=25

# Flask server settings (optional — secure defaults used if not set)
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-random-secret-key-here
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
