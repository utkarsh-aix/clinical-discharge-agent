# Virtual Environment
.venv/
venv/
ENV/
env/

# Python caching
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables (credentials)
.env
discharge_summary_agent/.env
.env.*
!.env.example

# Scratch and input/output directories
scratch_ocr/
discharge_summary_agent/scratch/
discharge_summary_agent/uploads/
discharge_summary_agent/outputs/
discharge_summary_agent/patients/

# OS/IDE settings
.DS_Store
.vscode/
.idea/

# Archives / Backups
*.zip
*.tar.gz
*.tgz

# Log files
*.log

# Pickle files — never commit (RCE risk if loaded from untrusted source)
*.pkl
*.pickle

# Accidental pip shell-redirect files (e.g. =3.5.0 created by unquoted pip install)
=*

# Flask-Limiter local storage (in-memory by default, but if file backend is used)
flask_limiter_storage/

# Patient data / PHI — belt-and-suspenders on top of outputs/ rule
discharge_summary_agent/**/*.json
!discharge_summary_agent/requirements*.json

# Test / temporary files
*.tmp
*.bak
.DS_Store
